# Discord bot token (required)
BOT_TOKEN=your_discord_bot_token_here

# Only guild this bot responds in (required)
DISCORD_GUILD_ID=your_guild_id_here

# Channel for bot status announcements (startup, updates)
BOTS_CHANNEL_ID=1519421945324765296

# YouTube Data API v3 key (required for youtube-alerter)
YOUTUBE_API_KEY=your_youtube_api_key_here

# SQLite database path (optional, default: ./data/ned-bot.db)
DATABASE_PATH=./data/ned-bot.db

# Max YouTube Data API quota units to spend on polling per day (project default: 10,000).
# Poll interval is computed from subscribed channel count (~4 units per channel per poll).
YOUTUBE_QUOTA_BUDGET_PER_DAY=8000
RSS_POLL_INTERVAL_SECONDS=300

# X (Twitter) Web Push — optional, enables the x-alerter module
# X_AUTH_TOKEN=
# X_CT0=

# Set to "production" to disable hot-reload in dev.ts
NODE_ENV=development

# Git auto-update — pull master and restart when new commits are pushed
# Requires the bot to run from a git clone with origin configured.
# Use PM2 (`npm run pm2:start`) so restarts are handled after updates.
GIT_AUTO_UPDATE_ENABLED=false
GIT_AUTO_UPDATE_INTERVAL_SECONDS=300
GIT_REMOTE=origin
GIT_BRANCH=master
# GIT_REPO_PATH=.
# GIT_REMOTE_REF=origin/master
