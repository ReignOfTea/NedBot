{
  "name": "ned-bot",
  "version": "1.0.0",
  "description": "Modular Discord bot with pluggable modules",
  "private": true,
  "type": "module",
  "main": "build/main.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/dev.ts",
    "start": "node build/main.js",
    "sync:commands": "tsx src/sync-commands.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@discordx/importer": "^1.3.3",
    "better-sqlite3": "^11.10.0",
    "chokidar": "^4.0.3",
    "discord.js": "^14.22.1",
    "discordx": "^11.13.2",
    "dotenv": "^16.6.1",
    "fast-xml-parser": "^5.9.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "xnotif": "^0.2.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.4.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
